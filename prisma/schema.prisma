// ==========================================
// EA LUMINI - Prisma Schema
// Banco de dados: PostgreSQL via Supabase
//
// Decisão arquitetural: Usamos dois URLs separados:
// - DATABASE_URL com pgbouncer para queries normais (connection pooling)
// - DIRECT_URL para migrations (precisa de conexão direta)
// ==========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum Role {
  ADMIN
  TERAPEUTA
  PACIENTE
}

enum AppointmentStatus {
  PENDENTE
  CONFIRMADO
  CONCLUIDO
  CANCELADO
}

enum Modality {
  ONLINE
  PRESENCIAL
  AMBOS
}

enum Gender {
  MASCULINO
  FEMININO
  NAO_BINARIO
  PREFIRO_NAO_INFORMAR
}

// ==========================================
// MODELS
// ==========================================

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(PACIENTE)
  active    Boolean   @default(true)
  avatarUrl String?
  phone     String?
  birthDate DateTime? // Data de nascimento (terapeuta/paciente)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  therapistProfile TherapistProfile?
  patientProfile   PatientProfile?
  refreshTokens    RefreshToken[]
  notifications    Notification[]
  sentReviews      Review[]          @relation("ReviewAuthor")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ==========================================
// PERFIL DO TERAPEUTA
// ==========================================

model TherapistProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  bio                   String?  @db.Text
  therapies             String[] // Array de especialidades
  price                 Decimal  @db.Decimal(10, 2)
  modality              Modality @default(AMBOS)
  location              String?
  city                  String?
  state                 String?
  country               String?  // País
  nationality           String?  // Nacionalidade
  professionalName      String?  // Nome como deseja aparecer publicamente
  documentId            String?  // Número do documento de identidade / Passaporte
  documentUrl           String?  // Storage path no bucket 'documents' (ex: documents/{userId}/file.pdf)
  documentFileName      String?  // Nome original do arquivo enviado
  rating                 Float    @default(0)
  reviewCount            Int      @default(0)
  approved               Boolean  @default(false)
  featured               Boolean  @default(false)
  yearsExp               Int?
  certifications         String[]
  languages              String[] @default(["Português"])
  whatsapp               String? // WhatsApp com código do país: +5511999999999
  professionalEmail     String? // Email profissional (pode ser diferente do login)
  instagram             String?
  facebook              String?
  websiteUrl            String? // Site pessoal/profissional
  greenApiInstanceId    String? // Green API instance ID
  greenApiToken         String? // Green API token
  sessionsPerMonthGoal  Int?    // objetivo: quantidade de sessões por mês
  // Preço oficial da sessão base
  minSessionPrice       Decimal? @db.Decimal(10, 2) // Preço mínimo da sessão
  maxSessionPrice       Decimal? @db.Decimal(10, 2) // Preço máximo da sessão
  baseCurrency          String?  @default("BRL")    // Moeda
  allowPromos           Boolean  @default(false)    // Autoriza promoções
  minPromoPrice         Decimal? @db.Decimal(10, 2) // Preço mínimo permitido em promoções
  timezone               String?  @default("America/Sao_Paulo") // Fuso horário para disponibilidade/agendamento
  wantCampaigns          Boolean  @default(false)  // Deseja aparecer em campanhas publicitárias
  allowAutoScheduling    Boolean  @default(false)  // Autoriza que o sistema agende automaticamente
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user               User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments       Appointment[]                @relation("TherapistAppointments")
  reviews            Review[]                     @relation("TherapistReviews")
  availability       Availability[]
  services           TherapistService[]
  consent            TherapistConsent?
  adminData          TherapistAdminData?
  aiConfig           TherapistAIConfig?
  targetAudience     TherapistTargetAudience?
  marketingMaterials TherapistMarketingMaterial[]
  paymentMethods     TherapistPaymentMethod[]
  paymentDetails     TherapistPaymentDetails?
  certificates       TherapistCertificate[]

  @@map("therapist_profiles")
}

// ==========================================
// DISPONIBILIDADE DO TERAPEUTA (calendário)
// ==========================================

model Availability {
  id           String   @id @default(cuid())
  therapistId  String
  dayOfWeek    Int // 0=Domingo, 1=Segunda, ... 6=Sábado
  startTime    String // "09:00"
  endTime      String // "18:00"
  slotDuration Int      @default(60) // minutos por sessão
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  therapist TherapistProfile @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@unique([therapistId, dayOfWeek, startTime])
  @@map("availability")
}

// ==========================================
// PERFIL DO PACIENTE
// ==========================================

model PatientProfile {
  id        String    @id @default(cuid())
  userId    String    @unique
  birthDate DateTime?
  gender    Gender?
  // Anamnese armazenada como JSON para flexibilidade futura
  anamnese  Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[] @relation("PatientAppointments")

  @@map("patient_profiles")
}

// ==========================================
// AGENDAMENTOS
// ==========================================

model Appointment {
  id              String            @id @default(cuid())
  therapistId     String
  patientId       String
  serviceId       String?
  date            DateTime
  durationMinutes Int               @default(60)
  status          AppointmentStatus @default(PENDENTE)
  price           Decimal           @db.Decimal(10, 2)
  commissionRate  Decimal           @db.Decimal(5, 2)
  commission      Decimal?          @db.Decimal(10, 2)
  therapistNet    Decimal?          @db.Decimal(10, 2)
  platformRevenue Decimal?          @db.Decimal(10, 2)
  notes           String?           @db.Text
  cancelReason    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  therapist TherapistProfile   @relation("TherapistAppointments", fields: [therapistId], references: [id])
  patient   PatientProfile     @relation("PatientAppointments", fields: [patientId], references: [id])
  service   TherapistService?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  review    Review?

  @@map("appointments")
}

// ==========================================
// AVALIAÇÕES
// ==========================================

model Review {
  id            String   @id @default(cuid())
  appointmentId String   @unique
  therapistId   String
  authorId      String
  rating        Int
  comment       String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment Appointment      @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  therapist   TherapistProfile @relation("TherapistReviews", fields: [therapistId], references: [id])
  author      User             @relation("ReviewAuthor", fields: [authorId], references: [id])

  @@map("reviews")
}

// ==========================================
// CONFIGURAÇÕES GLOBAIS DA PLATAFORMA
// ==========================================

model PlatformConfig {
  id              String   @id @default(cuid())
  commissionRate  Decimal  @default(10.00) @db.Decimal(5, 2)
  maintenanceMode Boolean  @default(false)
  allowNewSignups Boolean  @default(true)
  updatedAt       DateTime @updatedAt
  updatedBy       String?

  @@map("platform_config")
}

// ==========================================
// NOTIFICAÇÕES
// ==========================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String   @db.Text
  type      String   @default("INFO")
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ==========================================
// EA LUMINI — EXTENDED THERAPIST MODELS
// ==========================================

enum TherapistLevel {
  BASIC
  CERTIFIED
  PREMIUM
  FOUNDER
}

enum TherapistStatus {
  ACTIVE
  INACTIVE
  REVIEW
}

enum PaymentMethod {
  PIX
  CREDITO
  DEBITO
  BOLETO
  TRANSFERENCIA
  PAYPAL
  STRIPE
  MERCADOPAGO
  PREX
  CRIPTOMOEDA
  DINHEIRO
}

model TherapistService {
  id              String   @id @default(cuid())
  therapistId     String
  name            String
  description     String?  @db.Text
  problemsHelped  String?  @db.Text // Problemas que ajuda a resolver (ex: ansiedade, bloqueios emocionais, abundância, saúde)
  durationMinutes Int
  price           Decimal  @db.Decimal(10, 2)
  promoPrice      Decimal? @db.Decimal(10, 2)
  currency        String   @default("BRL")
  modality        Modality @default(AMBOS)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  therapist   TherapistProfile @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@map("therapist_services")
}

model TherapistConsent {
  id                   String    @id @default(cuid())
  therapistId          String    @unique
  termsAccepted        Boolean   @default(false)
  termsAcceptedAt      DateTime?
  privacyAccepted      Boolean   @default(false)
  privacyAcceptedAt    DateTime?
  imageRightsAccepted  Boolean   @default(false)
  imageRightsAt        DateTime?
  automationConsent    Boolean   @default(false)
  automationConsentAt  DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  therapist TherapistProfile @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@map("therapist_consents")
}

model TherapistAdminData {
  id                    String           @id @default(cuid())
  therapistId            String          @unique
  therapistCode          String?         @unique
  level                  TherapistLevel  @default(BASIC)
  status                 TherapistStatus @default(REVIEW)
  completenessScore     Int             @default(0)
  missingFields          String[]       @default([])
  promoAuthorized        Boolean         @default(false)
  automationAuthorized   Boolean         @default(false)
  internalNotes          String?         @db.Text
  country                String?         @default("BR")
  timezone               String?         @default("America/Sao_Paulo")
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  therapist TherapistProfile @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@map("therapist_admin_data")
}

model TherapistAIConfig {
  id                   String   @id @default(cuid())
  therapistId          String   @unique
  shortPitch           String?  @db.Text
  top3Benefits         String[] @default([])
  mainProblemsTreated  String[] @default([])
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  therapist TherapistProfile @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@map("therapist_ai_configs")
}

model TherapistTargetAudience {
  id           String   @id @default(cuid())
  therapistId  String   @unique
  ageGroups    String[] @default([])
  genders      String[] @default([])
  languages    String[] @default(["Português"])
  conditions   String[] @default([])
  specialNeeds String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  therapist TherapistProfile @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@map("therapist_target_audiences")
}

model TherapistMarketingMaterial {
  id          String   @id @default(cuid())
  therapistId String
  type        String
  url         String
  caption     String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  therapist TherapistProfile @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@map("therapist_marketing_materials")
}

model TherapistPaymentMethod {
  id          String        @id @default(cuid())
  therapistId String
  method      PaymentMethod

  therapist TherapistProfile @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@unique([therapistId, method])
  @@map("therapist_payment_methods")
}

// Dados para recebimento (titular, banco, conta, Pix) — 1:1 com terapeuta
model TherapistPaymentDetails {
  id                String   @id @default(cuid())
  therapistId       String   @unique
  accountHolderName String?  // Nome do titular
  bankName          String?  // Banco
  accountNumber     String?  // Número da conta
  pixKey            String?  // Chave Pix / Alias
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  therapist TherapistProfile @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@map("therapist_payment_details")
}

// Certificados em arquivo (upload) — visíveis no perfil público
model TherapistCertificate {
  id           String   @id @default(cuid())
  therapistId  String
  name         String   // rótulo ex.: "Curso de Reiki"
  fileUrl      String   // URL pública no storage
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  therapist TherapistProfile @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@map("therapist_certificates")
}
