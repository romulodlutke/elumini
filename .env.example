# ==========================================
# EALUMINI - Environment Variables
# Copie este arquivo para .env.local e preencha os valores
# ==========================================

# --- DATABASE (Supabase) ---
# Acesse: https://app.supabase.com -> seu projeto -> Settings -> Database
DATABASE_URL="postgresql://postgres:[SUA_SENHA]@db.[SEU_PROJECT_REF].supabase.co:5432/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[SUA_SENHA]@db.[SEU_PROJECT_REF].supabase.co:5432/postgres"

# --- SUPABASE ---
# Acesse: https://app.supabase.com -> seu projeto -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL="https://[SEU_PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[SUA_ANON_KEY]"
SUPABASE_SERVICE_ROLE_KEY="[SUA_SERVICE_ROLE_KEY]"

# --- JWT ---
# Gere com: openssl rand -base64 64
JWT_SECRET="seu_jwt_secret_super_seguro_aqui_minimo_32_caracteres"
JWT_REFRESH_SECRET="seu_refresh_secret_super_seguro_aqui_minimo_32_caracteres"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --- APP ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# --- EMAIL (Opcional - para recuperação de senha) ---
# Configure com Resend, SendGrid ou SMTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="seu@email.com"
SMTP_PASS="sua_senha_app"
EMAIL_FROM="EALumini <noreply@ealumini.com>"
